# Copy this file to .env and adjust if needed. .env itself is gitignored.

POSTGRES_USER=a2user
POSTGRES_PASSWORD=a2pass
POSTGRES_DB=a2db

# Used by the app. When running via docker compose, "db" is the service
# name below, not localhost.
DATABASE_URL=postgresql://a2user:a2pass@db:5432/a2db

# memory | postgres  (defaults to postgres automatically if DATABASE_URL is set)
STORAGE=postgres
